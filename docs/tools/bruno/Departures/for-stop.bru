meta {
  name: Departures for a stop
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/v1/stops/200060/departures
  body: none
  auth: none
}

headers {
  X-Krail-Version: {{appVersion}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}

docs {
  Replace `200060` (Town Hall) with the stop ID you want to inspect.
  Optional query params: `date=YYYYMMDD`, `time=HHmm`.
}
